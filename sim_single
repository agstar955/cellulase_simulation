import pygame
import random
import math

R = 10
R_SQRT = R / math.sqrt(2)

N=50
SCREEN = R_SQRT * N * 2

DELAY = 200

TIMER = 0
TIME_LIMIT = 5000

cellulose = []
cellulace=[]
chains = []
moving = []

font = None
cnt=0

class Cellulose():
    def __init__(self,idx, chain, x, y, r,fixed=False,end=False):
