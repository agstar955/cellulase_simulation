        self.chain_idx = chain
        self.x = x
        self.y = y
        self.dx = 0 # 상대 좌표
        self.dy = 0
        self.r = r
        self.color = (0, 120, 0)
        self.fixed = fixed
        self.isEnd = end

    def draw(self, screen):
