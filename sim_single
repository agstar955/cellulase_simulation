    def setXY(self):
        self.x = chains[self.chain_idx].center_x + self.dx
        self.y = chains[self.chain_idx].center_y + self.dy

    def getPos(self):
        self.setXY()
        return (self.x,self.y)

    def update(self):
        pass

class Cellulase():
    def __init__(self, idx, chain, x, y, r):
        self.idx = idx
        self.chain_idx = chain
        self.x = x
        self.y = y
        self.dx = 0 # 상대 좌표
        self.dy = 0
        self.r = r
        self.color = (255, 0, 0)
        self.fixed = False
        self.bond_time = -1
        self.bonded = None
        self.idx_in_chain = None

    def draw(self, screen):
        pygame.draw.circle(screen, self.color, (self.x, self.y), self.r)

    def setXY(self):
        self.x = chains[self.chain_idx].center_x + self.dx
        self.y = chains[self.chain_idx].center_y + self.dy

    def getPos(self):
        self.setXY()
        return (self.x,self.y)
    
    def unbond(self):
        pass

    def checkBond(self, c,idx):
        return True

    def update(self):
        if self.bond_time > 0:
            self.bond_time -= 1
            if self.bond_time == 0:
                self.unbond()
                chains[self.chain_idx].unbond(chains[self.chain_idx].bonded[self.idx_in_chain],self.idx_in_chain)
                self.bonded = None
                self.bond_time = -DELAY
        elif self.bond_time<-1:
            self.bond_time +=1
        elif self.bonded is None:
            pos = self.getPos()
            foundCell = False
            for i,chain in enumerate(chains):
                if not moving[i]: continue
                if chain.idx == self.chain_idx: continue
                for j,c in enumerate(chain.components):
                    if chain.bonded is None and c.color == (0,120,0):
                        if not self.checkBond(c,j): continue
                        cell_pos = c.getPos()
                        if math.hypot(cell_pos[0]-pos[0],cell_pos[1]-pos[1]) <= 2*R:
                            chains[self.chain_idx].bond(chain.idx,self.idx_in_chain)
                            self.bonded = c.idx
                            self.bond_time = DELAY
                            foundCell = True
                            break
                if foundCell: break

class Endoglucanase(Cellulase):
    def __init__(self, idx, c, x, y, r):
        super().__init__(idx, c, x, y, r)
        self.color = (255, 0, 0)
    def unbond(self):
        chains[chains[self.chain_idx].bonded[self.idx_in_chain]].divide(self.bonded)
    def checkBond(self, c,idx):
        chain = chains[c.chain_idx]
        return (not c.isEnd and not c.fixed and len(chain.components)>6
            and (chain.components[0].fixed or chain.components[-1].fixed or (idx >= 3 and idx < len(chain.components)-4) or idx == len(chain.components)//2))

class Exoglucanase(Cellulase):
    def __init__(self, idx, c, x, y, r):
        super().__init__(idx, c, x, y, r)
        self.color = (0, 255, 0)
    
    def checkBond(self,c,idx):
        chain = chains[c.chain_idx]
        return (c.isEnd and len(chain.components)<=6 and len(chain.components)>2)
    
    def unbond(self):
        chain = chains[chains[self.chain_idx].bonded[self.idx_in_chain]]
        chain.cut(chain.components[0].idx == self.bonded)

    def update(self):
        if self.bond_time > 0:
            chain = chains[chains[self.chain_idx].bonded[self.idx_in_chain]]
            direction = 0
            if chain.components[0].idx == self.bonded:
                for c in chain.components:
                    c.dx-=1/math.sqrt(2)
                    c.dy-=1/math.sqrt(2)
            else:
                direction = -1
                for c in chain.components:
                    c.dx+=1/math.sqrt(2)
                    c.dy+=1/math.sqrt(2)
            self.bond_time+=1

            if self.bond_time == 21:
                self.unbond()
                chains[self.chain_idx].unbond(chains[self.chain_idx].bonded[self.idx_in_chain],self.idx_in_chain)
                self.bonded = None

                if len(chain.components) > 2:
                    c = chain.components[direction]
                    chains[self.chain_idx].bond(chain.idx,self.idx_in_chain)
                    self.bonded = c.idx
                    self.bond_time = 1
                else:
                    self.bond_time = -DELAY

        elif self.bond_time<-1:
            self.bond_time +=1

        elif self.bonded is None:
            pos = self.getPos()
            foundCell = False
            for i,chain in enumerate(chains):
                if not moving[i]: continue
                if chain.idx == self.chain_idx: continue
                for j,c in enumerate(chain.components):
                    if chain.bonded is None and c.color == (0,120,0):
                        if not self.checkBond(c,j): continue
                        cell_pos = c.getPos()
                        if math.hypot(cell_pos[0]-pos[0],cell_pos[1]-pos[1]) <= 2*R:
                            chains[self.chain_idx].bond(chain.idx,self.idx_in_chain)
                            self.bonded = c.idx
                            self.bond_time = 1
                            foundCell = True
                            break
                if foundCell: break
    
